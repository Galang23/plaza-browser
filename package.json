{
  "name": "plaza-browser",
  "version": "1.3.6",
  "description": "Electron-based browser with hierarchical workspace and tab management",
  "main": "./out/main/index.js",
  "author": "Galang23 <Galang23@users.noreply.github.com>",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-vite build && electron-builder",
    "audit:preload": "bun run scripts/audit-preload.ts"
  },
  "engines": {
    "electron": ">=42.4.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "install-electron": "^1.0.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^4.4.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "build": {
    "appId": "com.galang23.plaza-browser",
    "productName": "Plaza Browser",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "mac": {
      "target": ["dmg"]
    },
    "win": {
      "target": ["nsis"]
    }
  }
}
